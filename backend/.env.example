# Environment configuration template

NODE_ENV=development
PORT=5000
SERVE_FRONTEND=false

# MySQL/MariaDB connection used by Prisma (compatible with phpMyAdmin)
DATABASE_URL="mysql://draymih_user:change_this_password@127.0.0.1:3306/draymih_db"
# Windows/XAMPP example: C:/xampp/mysql/bin/mysqldump.exe
MYSQLDUMP_PATH="mysqldump"

# JWT secrets
JWT_ACCESS_SECRET="your_jwt_access_secret_key"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key"

# Required only when running the database seed for the first time
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_INITIAL_PASSWORD="replace_with_a_long_random_password"

# SMTP Mail configurations
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"
SMTP_FROM="no-reply@yourdomain.com"

# Public URL and notifications target
CORS_ORIGIN="http://localhost:5173"
FIRM_NOTIFICATION_EMAIL="firm@yourdomain.com"
