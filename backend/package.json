{
  "name": "law-office-backend",
  "version": "1.0.0",
  "description": "Production TypeScript Backend for Saud bin Fahd Al-Duraymih Law Office",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "postinstall": "prisma generate --schema=../prisma/schema.prisma",
    "build": "prisma generate --schema=../prisma/schema.prisma && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../prisma/schema.prisma",
    "prisma:seed": "node scripts/run-seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "prisma": "^5.22.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {},
  "prisma": {
    "schema": "../prisma/schema.prisma",
    "seed": "node scripts/run-seed.js"
  }
}
